<!--calculadora simples-->

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <label for="num1">Digite o primeiro valor: </label>
    <input type="number" id="num1"><br><br>
    <label for="num2">Digite o segundo valor: </label>
    <input type="number" id="num2"><br><br>

    <button type="button" onclick="calcular()">Calcular</button>

    <script>
        function calcular() {
            let numero1 = parseFloat(document.getElementById("num1").value); //getElementById serve para acessar um elemento especifico no HTML pelo ID
            let numero2 = parseFloat(document.getElementById("num2").value);

            let soma = numero1 + numero2;
            let subtracao = numero1 - numero2;
            let multiplicacao = numero1 * numero2;

            let div = false;
            if (numero2 === 0) {
                divisao = "Erro: divisão por zero não existe!"; 
                div = true;
            } 
            else {
                divisao = numero1 / numero2; 

            }

            document.write("Soma: " + soma + "<br>");
            console.log(soma);
            document.write("Subtracao: " + subtracao + "<br>");
            console.log(subtracao);
            document.write("Multiplicacao: " + multiplicacao + "<br>");
            console.log(multiplicacao);
            if (div == false) {
                document.write("Divisao: " + divisao + "<br>");
                } else {
            document.write(divisao);
            console.log(divisao);
                }        
        }
    </script>
</body>
</html>
